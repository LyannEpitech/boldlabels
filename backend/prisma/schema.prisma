generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Template {
  id             String    @id @default(uuid())
  name           String
  description    String?
  width          Float
  height         Float
  unit           String    @default("mm")
  backgroundColor String   @default("#FFFFFF")
  borderWidth    Float     @default(0)
  borderColor    String    @default("#000000")
  borderRadius   Float     @default(0)
  elements       TemplateElement[]
  mappings       Mapping[]
  layoutPresets  LayoutPreset[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model TemplateElement {
  id           String   @id @default(uuid())
  templateId   String
  template     Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  type         String
  variableName String
  x            Float
  y            Float
  width        Float
  height       Float
  rotation     Float    @default(0)
  properties   String
  zIndex       Int
  
  @@index([templateId])
}

model Mapping {
  id             String          @id @default(uuid())
  name           String
  templateId     String
  template       Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  columnMappings ColumnMapping[]
  csvSample      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  @@index([templateId])
}

model ColumnMapping {
  id           String  @id @default(uuid())
  mappingId    String
  mapping      Mapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)
  variableName String
  columnIndex  Int
  columnName   String
  
  @@index([mappingId])
}

model LayoutPreset {
  id                String   @id @default(uuid())
  name              String
  templateId        String
  template          Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  pageSize          String   @default("A4")
  orientation       String   @default("portrait")
  marginTop         Float    @default(10)
  marginRight       Float    @default(10)
  marginBottom      Float    @default(10)
  marginLeft        Float    @default(10)
  labelsPerRow      Int      @default(3)
  labelsPerColumn   Int      @default(8)
  horizontalSpacing Float    @default(2)
  verticalSpacing   Float    @default(0)
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([templateId])
}
